# SQL Server (use hostname ou IP_SERVIDOR_OXEN conforme seu ambiente)
DB_SERVER=IP_SERVIDOR_OXEN
DB_NAME=nome_do_banco
DB_USER=usuario_sql
DB_PASSWORD=SUA_SENHA_SEGURA

# API Compleo — token Bearer (nunca commitar valor real)
COMPLEO_API_TOKEN=YOUR_COMPLEO_API_TOKEN

# Identificador da organização na API Compleo (substitua pelo ID da sua conta)
COMPLEO_COMPANY_ID=YOUR_COMPANY_ID

# Base da API (opcional; padrão: https://api.compleo.app/public)
# COMPLEO_API_BASE_URL=https://api.compleo.app/public

# Períodos (scripts que suportam janela temporal: metric, candidat, jobAdd, moviment)
# START_DATE=2024-01-01
# END_DATE=2024-12-31
# PERIOD_MODE=yearly
# PERIOD_MODE pode ser: yearly, monthly, daily (conforme o script)
